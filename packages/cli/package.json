{
  "name": "@sprawlens/cli",
  "version": "0.2.1",
  "description": "Visualize the structure of any TypeScript, Go, Rust or MoonBit repository",
  "keywords": [
    "code-visualization",
    "go",
    "lsp",
    "moonbit",
    "rust",
    "treemap",
    "typescript",
    "voronoi"
  ],
  "homepage": "https://github.com/mizchi/sprawlens#readme",
  "bugs": {
    "url": "https://github.com/mizchi/sprawlens/issues"
  },
  "license": "MIT",
  "author": "mizchi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizchi/sprawlens.git",
    "directory": "packages/cli"
  },
  "bin": {
    "sprawlens": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.js",
    "exports": {
      ".": "./dist/index.js"
    },
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:server": "tsx watch src/devServer.ts sprawlens=../..",
    "build": "node build.mjs"
  },
  "dependencies": {
    "@cdktf/hcl2json": "^0.21.0",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "picomatch": "^4.0.4",
    "smol-toml": "^1.7.0",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^6.0.0",
    "typescript-language-server": "^5.3.0",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@sprawlens/analyzer-terraform": "workspace:*",
    "@sprawlens/analyzer-ts": "workspace:*",
    "@sprawlens/layout": "workspace:^",
    "@sprawlens/providers": "workspace:*",
    "@sprawlens/schema": "workspace:*",
    "@sprawlens/server": "workspace:*",
    "@sprawlens/viz": "workspace:*",
    "tsdown": "^0.22.3"
  }
}
