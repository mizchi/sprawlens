{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "noEmit": true,
    // the headless SVG renderer pulls @sprawlens/viz preact components, so
    // type-check them the way viz does (allowImportingTsExtensions is in base)
    "jsxImportSource": "preact"
  },
  "include": ["src"]
}
