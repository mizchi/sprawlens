{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "noEmit": true,
    // the headless SVG renderer pulls @sprawlens/viz preact components (.tsx,
    // ts-extension imports), so type-check them the way viz does
    "jsxImportSource": "preact",
    "allowImportingTsExtensions": true
  },
  "include": ["src"]
}
