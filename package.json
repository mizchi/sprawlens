{
  "name": "sprawlens",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "bench": "vitest bench --run",
    "typecheck": "pnpm -r --filter=!sprawlens exec tsgo --noEmit -p tsconfig.json",
    "typecheck:tsc": "pnpm -r --filter=!sprawlens exec tsc --noEmit -p tsconfig.json",
    "lint": "oxlint",
    "lint:layers": "node tools/check-layers.mjs",
    "lint:exports": "knip --include exports,types,nsExports,nsTypes",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "dev": "concurrently -k -n viz,api -c green,cyan \"pnpm --filter @sprawlens/viz dev\" \"pnpm --filter @sprawlens/cli dev:server\"",
    "dev:viz": "pnpm --filter @sprawlens/viz dev",
    "build": "pnpm --filter @sprawlens/viz build && pnpm --filter @sprawlens/cli build",
    "dev:server": "pnpm --filter @sprawlens/cli dev:server",
    "cli": "pnpm --filter @sprawlens/cli dev",
    "test:render": "playwright test -c playwright.render.config.ts",
    "test:render:update": "UPDATE_SVG=1 playwright test -c playwright.render.config.ts",
    "test:render:vlm": "playwright test -c playwright.vlm.config.ts",
    "trace:self": "tsx e2e/captureSelfTrace.mts",
    "preview:atlas": "tsx e2e/capturePreview.mts"
  },
  "dependencies": {
    "preact": "^10.29.2",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.4",
    "@playwright/test": "^1.60.0",
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^22.10.2",
    "@typescript/native-preview": "^7.0.0-dev.20260623.1",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "knip": "^6.17.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsx": "^4.19.2",
    "typescript-language-server": "^5.3.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
